# 阶段一：构建 Vue3 代码
FROM node:20-alpine AS builder
WORKDIR /app

# 避免 corepack 下载使用 node:sqlite 的 pnpm v10 导致 Node 20 不兼容报错
RUN npm install -g pnpm@9

# 利用 Docker 缓存层安装依赖
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# 复制源码并打包
COPY . .
RUN pnpm run build

# 阶段二：使用 Nginx 部署静态文件
FROM nginx:alpine
# 将构建好的 dist 文件复制到 Nginx 默认目录
COPY --from=builder /app/dist /usr/share/nginx/html

# 暴露 Nginx 端口
EXPOSE 5173

# 运行 Nginx
CMD ["nginx", "-g", "daemon off;"]

# 将生产环境反向代理与 HTTPS 配置塞进容器
COPY default.conf.prod /etc/nginx/conf.d/default.conf
